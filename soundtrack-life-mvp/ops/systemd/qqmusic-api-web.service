[Unit]
Description=QQMusicApi Web Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/QQMusicApi
Environment=QQMUSIC_SERVER_HOST=127.0.0.1
Environment=QQMUSIC_SERVER_PORT=8080
ExecStart=/opt/QQMusicApi/.venv/bin/uv run --no-sync web/run.py
Restart=always
RestartSec=5
TimeoutStartSec=30
TimeoutStopSec=8
KillMode=control-group
KillSignal=SIGTERM
FinalKillSignal=SIGKILL
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
