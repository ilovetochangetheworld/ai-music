{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lulu.yixin.info/schema/device-latency-calibration.schema.json",
  "title": "DeviceLatencyCalibration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "method", "offsetMs", "jitterMs", "sampleCount", "confidence", "status", "sampleRateHz", "createdAt", "expiresAt"],
  "properties": {
    "version": { "const": "1.0" },
    "method": { "const": "user_tap" },
    "offsetMs": { "type": "number", "minimum": 0, "maximum": 250 },
    "jitterMs": { "type": "number", "minimum": 0 },
    "sampleCount": { "type": "integer", "minimum": 0, "maximum": 8 },
    "confidence": { "enum": ["high", "medium", "low"] },
    "status": { "enum": ["valid", "low_confidence"] },
    "sampleRateHz": { "type": "number", "exclusiveMinimum": 0 },
    "createdAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" }
  }
}
